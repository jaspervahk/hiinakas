rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == "7d3zgIRy43OClSXUDhnsLmhDNwg2";
    }
    match /replayChallenges/{id} {
      allow read: if request.auth != null && request.auth.uid == "7d3zgIRy43OClSXUDhnsLmhDNwg2";
    }
  }
}
